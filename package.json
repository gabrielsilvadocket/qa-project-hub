{
  "name": "qa-project-hub",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:homolog": "cypress open --env environment=homologation",
    "cy:prod": "cypress open --env environment=production",
    "cy:run:homolog": "cypress run --env environment=homologation",
    "cy:run:prod": "cypress run --env environment=production",
    "report:merge": "mochawesome-merge cypress/reports/mocha/*.json > cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json --reportDir cypress/reports/html --inline",
    "report:full": "npm run report:merge && npm run report:generate"
  },
